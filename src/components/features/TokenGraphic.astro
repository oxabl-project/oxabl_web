---
const tokens = [
  { kind: "kw", text: "DEFINE" },
  { kind: "kw", text: "VARIABLE" },
  { kind: "id", text: "x" },
  { kind: "kw", text: "AS" },
  { kind: "type", text: "INTEGER" },
  { kind: "punct", text: "." },
]
---

<div
  class="flex h-full min-h-40 flex-col justify-center gap-3 rounded-3xl border border-border bg-card p-5 [box-shadow:var(--card-shadow)]"
  aria-hidden="true"
>
  <div class="flex items-center justify-between text-[10px] tracking-widest text-muted-foreground uppercase">
    <span>token stream</span>
    <span class="text-oxabl-green">6 kinds</span>
  </div>
  <div class="flex flex-wrap gap-2">
    {
      tokens.map((t) => (
        <span
          class:list={[
            "inline-flex items-center rounded-md border px-2 py-1 font-mono text-[11px] font-medium",
            t.kind === "kw" &&
              "border-oxabl-green/30 bg-oxabl-green/10 text-oxabl-green",
            t.kind === "id" &&
              "border-border bg-muted text-foreground",
            t.kind === "type" &&
              "border-sky-500/30 bg-sky-500/10 text-sky-700 dark:text-sky-300",
            t.kind === "punct" &&
              "border-border bg-background text-muted-foreground",
          ]}
        >
          <span class="mr-1.5 text-[9px] opacity-50">{t.kind}</span>
          {t.text}
        </span>
      ))
    }
  </div>
  <div class="font-mono text-[10px] text-muted-foreground/70">
    def var x as int. → same stream
  </div>
</div>
